# BluePulse Nexus – verschluesselte Restic-Backups

BACKUP_REPOSITORY_PATH=./backups/restic
BACKUP_RECOVERY_PATH=./backups/recovery
BACKUP_SOURCE_ENV_FILE=./.env.production
RESTIC_PASSWORD_FILE_HOST=./.secrets/restic-password

BACKUP_HOSTNAME=bluepulse-nexus
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=5
BACKUP_KEEP_MONTHLY=12
BACKUP_KEEP_YEARLY=3
BACKUP_CHECK_AFTER_BACKUP=true
