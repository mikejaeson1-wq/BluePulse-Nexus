{
  "name": "bluepulse-nexus",
  "private": true,
  "version": "0.3.0-alpha.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "vite",
    "dev:web": "vite",
    "dev:api": "npm run dev --workspace=@bluepulse/api",
    "start:api": "npm run start --workspace=@bluepulse/api",
    "test:api": "npm run test --workspace=@bluepulse/api",
    "build": "vite build",
    "build:web": "vite build",
    "lint": "oxlint",
    "preview": "vite preview",
    "db:migrate": "npm run db:migrate --workspace=@bluepulse/api",
    "db:status": "npm run db:status --workspace=@bluepulse/api"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@fortawesome/fontawesome-free": "^7.3.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@react-three/postprocessing": "^3.0.4",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "gsap": "^3.15.0",
    "jszip": "^3.10.1",
    "postprocessing": "^6.39.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "oxlint": "^1.71.0",
    "vite": "^8.1.1",
    "vite-plugin-glsl": "^1.6.0"
  }
}
