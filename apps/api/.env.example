NODE_ENV=development

API_HOST=127.0.0.1
API_PORT=3001

APP_NAME=BluePulse Nexus API
APP_VERSION=0.3.0-alpha.0

LOG_LEVEL=info

DATABASE_URL=postgresql://bluepulse:bluepulse_dev_change_me@127.0.0.1:5432/bluepulse_nexus
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000

MEDIA_STORAGE_DIR=./storage/media
MEDIA_MAX_FILE_SIZE_BYTES=15728640

AUTH_REQUIRED=true
AUTH_COOKIE_NAME=bluepulse_nexus_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=604800

CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_DUPLICATE_WINDOW_SECONDS=60
CONTACT_IP_HASH_SECRET=replace-with-a-long-random-secret
