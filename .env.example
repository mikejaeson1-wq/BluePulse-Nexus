# Allgemeiner Datenmodus:
# local = Browser-Speicher
# api   = Nexus-API
VITE_DATA_MODE=local

# Builder-Seiten können bereits unabhängig von den übrigen
# Website-Inhalten über PostgreSQL laufen.
VITE_PAGE_DATA_MODE=api

# Während der Entwicklung über den Vite-Proxy erreichbar.
VITE_API_BASE_URL=/api

# Wird unter anderem in Nexus-Backups gespeichert.
VITE_APP_VERSION=0.3.0-alpha.0