NODE_ENV=development

API_HOST=127.0.0.1
API_PORT=3001

APP_NAME=BluePulse Nexus API
APP_VERSION=0.3.0-alpha.0
APP_PUBLIC_URL=http://127.0.0.1:5173

LOG_LEVEL=info

DATABASE_URL=postgresql://bluepulse:bluepulse_dev_change_me@127.0.0.1:5432/bluepulse_nexus
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000

MEDIA_STORAGE_DIR=./storage/media
MEDIA_MAX_FILE_SIZE_BYTES=15728640

AUTH_REQUIRED=true
AUTH_COOKIE_NAME=bluepulse_nexus_session
AUTH_COOKIE_SECURE=false
AUTH_SESSION_TTL_SECONDS=604800

CONTACT_RATE_LIMIT_MAX=5
CONTACT_RATE_LIMIT_WINDOW_MS=900000
CONTACT_DUPLICATE_WINDOW_SECONDS=60
CONTACT_IP_HASH_SECRET=replace-with-a-long-random-secret

MAIL_ENABLED=false
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_SECURE=true
MAIL_USER=bluepulsekontakt@gmail.com
MAIL_PASSWORD=replace-with-google-app-password
MAIL_FROM_NAME=BluePulse Tierschutz
MAIL_FROM_ADDRESS=bluepulsekontakt@gmail.com
MAIL_TLS_REJECT_UNAUTHORIZED=true
MAIL_CONNECTION_TIMEOUT_MS=10000
MAIL_GREETING_TIMEOUT_MS=10000
MAIL_SOCKET_TIMEOUT_MS=20000

CONTACT_NOTIFICATION_TO=bluepulsekontakt@gmail.com
CONTACT_NOTIFICATION_SUBJECT_PREFIX=[BluePulse Kontakt]
